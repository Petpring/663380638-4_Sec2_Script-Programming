          "text": [
            "กรุณาป้อนตัวเลข: 0\n",
            "0 เป็นศูนย์ และเป็นเลขคู่\n"
          ]
        }
      ],
      "source": [
        "\n",
        "num = int(input(\"กรุณาป้อนตัวเลข: \"))\n",
        "\n",
        "\n",
        "if num > 0:\n",
        "    sign = \"บวก\"\n",
        "elif num < 0:\n",
        "    sign = \"ลบ\"\n",
        "else:\n",
        "    sign = \"ศูนย์\"\n",
        "\n",
        "\n",
        "if num % 2 == 0:\n",
        "    parity = \"เลขคู่\"\n",
        "else:\n",
        "    parity = \"เลขคี่\"\n",
        "\n",
        "# แสดงผลทั้งสองอย่าง\n",
        "print(f\"{num} เป็น{sign} และเป็น{parity}\")"
      ]
    }
  ]
}